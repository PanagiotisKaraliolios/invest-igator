		"ai:sweep": "bun run src/server/jobs/sweep-ai-reservations.ts",
		"build": "next build",
		"check": "biome check ./src",
		"check:unsafe": "biome check --write --unsafe ./src",
		"check:write": "biome check --write ./src",
		"currency:backfill": "bun run src/server/jobs/backfill-currency.ts",
		"db:generate": "prisma migrate dev",
		"db:migrate": "prisma migrate deploy",
		"db:mock": "bun prisma/mock.ts",
		"db:push": "prisma db push",
		"db:seed": "bun prisma/seed.ts",
		"db:studio": "prisma studio --port 5000",
		"dev": "next dev --turbo",
		"eval:advice": "AI_EVAL_LIVE=1 bun test --timeout 120000 src/server/ai/evals/tier1/advice-boundary.eval.test.ts",
		"eval:tier1": "AI_EVAL_LIVE=1 bun test --timeout 120000 src/server/ai/evals/tier1",
		"ingest:fx": "bun run src/server/jobs/ingest-fx.ts",
		"ingest:yahoo": "bun run src/server/jobs/ingest-yahoo.ts",
		"postinstall": "prisma generate",
		"preview": "next build && next start",
		"prices:fetch": "bun run scripts/fetch-model-prices.ts",
		"start": "next start",
		"test:db": "bun test prisma/ai-schema.test.ts prisma/ai-telemetry-dbsink.test.ts prisma/ai-quota.test.ts prisma/ai-telemetry-ledger.test.ts prisma/ai-tool-authz.test.ts",
		"test:e2e": "bunx playwright test",
		"test:e2e:headed": "bunx playwright test --headed",
		"test:e2e:install": "bunx playwright install --with-deps",
		"test:e2e:noweb": "PW_SKIP_WEBSERVER=1 bunx playwright test",
		"test:e2e:ui": "bunx playwright test --ui",
		"test:e2e:ui:noweb": "PW_SKIP_WEBSERVER=1 bunx playwright test --ui",
		"test:unit": "bun test --isolate src",
		"typecheck": "tsc --noEmit",
		"verify:secrets": "bash scripts/verify-secrets.sh"
	},
