# --- App ---
APP_NAME=Invest-igator
NODE_ENV=production
BETTER_AUTH_SECRET=change-me
AUTH_TRUST_HOST=true
PASSWORD_PEPPER=change-me

# Optional OAuth (Discord sample)
AUTH_DISCORD_ID=
AUTH_DISCORD_SECRET=

# External APIs
POLYGON_API_KEY=

# Prisma / Postgres wired via compose db service
DATABASE_URL=postgresql://postgres:postgres@db:5432/investigator

# InfluxDB wired via compose influx service
INFLUXDB_URL=http://influx:8086
INFLUXDB_ORG=local-org
INFLUXDB_BUCKET=daily
INFLUXDB_TOKEN=local-secret-token

# Yahoo (default baked in)
YAHOO_API_URL=https://query1.finance.yahoo.com/v8/finance

# Optional overrides
POLYGON_API_URL=https://api.polygon.io

# CI/CD image name (optional)
# DOCKER_IMAGE=your-dockerhub-user/invest-igator:latest
# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# Better Auth
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST=true

# Better Auth Discord Provider
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""

# Prisma
# https://www.prisma.io/docs/reference/database-reference/connection-urls#env
DATABASE_URL="postgresql://postgres:password@localhost:5432/invest-igator"

# Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=""
NEXT_PUBLIC_UMAMI_WEBSITE_ID=""

# Admin User
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
ADMIN_NAME=""

# --- AI layer (Phase 0) ---

# Platform LLM provider (Azure OpenAI) — REQUIRED; the app refuses to boot without them.
# Empty string == unset (emptyStringAsUndefined), so put a placeholder even if unused locally.
# Azure OpenAI is self-serve — no access form.
AZURE_OPENAI_RESOURCE_NAME=placeholder   # the resource NAME, e.g. my-aoai — NOT the full URL.
                                 # The SDK appends /v1{path} itself; a value ending in /v1 -> 404.
AZURE_OPENAI_API_KEY=placeholder
AZURE_OPENAI_CHAT_DEPLOYMENT=placeholder # the DEPLOYMENT name — this is the SDK "model id"
AZURE_OPENAI_CHAT_MODEL=gpt-5.4-mini     # the REAL model — this is what we PRICE on;
                                         # MUST be a key in models.snapshot.json

# BYOK credential encryption (AES-256-GCM keyring). Optional: BYOK degrades without them.
# Generate a key:  openssl rand -base64 32
# Rotate by adding a new kid and pointing AI_CRED_ACTIVE_KID at it. NEVER remove an old
# kid until every row sealed with it has been re-sealed — old kids are decrypt-only, not dead.
AI_CRED_KEYS={"k1":"REPLACE_WITH_openssl_rand_base64_32"}
AI_CRED_ACTIVE_KID=k1

# API key verification (Phase 2 prerequisite). Min 32 chars.
# Generate:  openssl rand -base64 32
AI_API_KEY_PEPPER=
