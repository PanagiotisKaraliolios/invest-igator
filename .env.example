# Since the ".env" file is gitignored, copy this file to ".env" and fill in your
# secrets. Keep this file up-to-date when you add new variables — and keep the
# schema in "/src/env.js" in sync.
#
# This file is committed to version control, so do NOT put real secrets here.

# --- App ---
APP_NAME=Invest-igator
NODE_ENV=production

# --- Better Auth ---
BETTER_AUTH_SECRET=change-me            # must be >= 32 chars
BETTER_AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true
PASSWORD_PEPPER=change-me

# Better Auth Discord provider — REQUIRED by src/env.js (both z.string()) and
# registered unconditionally in src/lib/auth.ts. Because src/env.js uses
# emptyStringAsUndefined, leaving these blank makes env validation FAIL FAST at
# startup; with SKIP_ENV_VALIDATION=1 (the compose default) the app boots but the
# Discord provider is misconfigured. Set real values, or remove the Discord
# provider in src/lib/auth.ts if you don't want it.
AUTH_DISCORD_ID=
AUTH_DISCORD_SECRET=

# --- Postgres (consumed by docker-compose db service + DATABASE_URL) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=investigator
# In compose this is derived from POSTGRES_* and points at the `db` service.
DATABASE_URL=postgresql://postgres:postgres@db:5432/investigator

# --- InfluxDB 2.x ---
# EXTERNAL by default: point this at your own instance. If you enable the
# optional internal `influxdb` service in docker-compose.yml, use
# INFLUXDB_URL=http://influxdb:8086 instead.
INFLUXDB_URL=http://localhost:8086
INFLUXDB_ORG=local-org
INFLUXDB_BUCKET=daily
INFLUXDB_TOKEN=local-secret-token
# Only used by the optional internal influxdb service's first-run setup:
# INFLUXDB_USERNAME=admin
# INFLUXDB_PASSWORD=changeme-please

# --- Email (required by src/env.js) ---
EMAIL_FROM=no-reply@example.com
EMAIL_SERVER=smtp://user:pass@smtp.example.com:587

# --- Cloudflare R2 storage (required by src/env.js) ---
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ACCESS_KEY_ID=
CLOUDFLARE_SECRET_ACCESS_KEY=
CLOUDFLARE_BUCKET_NAME=
# Optional public base URL for served R2 assets:
# CLOUDFLARE_R2_PUBLIC_URL=

# --- Market data APIs ---
POLYGON_API_KEY=
POLYGON_API_URL=https://api.polygon.io
# Yahoo (base URL; code appends /chart/<symbol>). Matches src/env.js default.
YAHOO_API_URL=https://query2.finance.yahoo.com/v8/finance

# --- Analytics / Ads (all optional, NEXT_PUBLIC_*) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
NEXT_PUBLIC_ADSENSE_CLIENT_ID=
NEXT_PUBLIC_ADSENSE_SLOT_DASHBOARD=
NEXT_PUBLIC_ADSENSE_SLOT_LANDING=
NEXT_PUBLIC_ADSENSE_SLOT_WATCHLIST=

# --- Admin seed user (prisma/seed.ts creates this on first boot) ---
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=

# --- CI/CD image name (optional) ---
# DOCKER_IMAGE=your-dockerhub-user/invest-igator:latest
